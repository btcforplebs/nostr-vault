# APNs Configuration
# Get these from Apple Developer Portal:
# 1. Create APNs Key (Certificates, Identifiers & Profiles > Keys)
# 2. Download the .p8 file and save as apns_key.pem
APNS_KEY_PATH=./certs/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_TOPIC=com.yourcompany.nostrvault
APNS_USE_SANDBOX=false

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=7766
DATABASE_URL=sqlite+aiosqlite:///./push_server.db

# Optional: Custom relay list (comma-separated)
# CUSTOM_RELAYS=wss://relay.damus.io,wss://relay.primal.net
